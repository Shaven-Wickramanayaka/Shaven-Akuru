---
const {pathname} = Astro.url;

---

<nav class="bg-amber-400 flex items-center justify-center p-3">
    <div class="text-2xl font-[Shaven Akuru] navbar-links shaven-akuru">
        <a class={pathname.slice(1) === '' ? 'active p-2 mx-2' : 'p-2 mx-2'} href="/">
            Home
        </a>
                <a class={pathname.slice(1) === 'install' ? 'active p-2 mx-2' : 'p-2 mx-2'} href="/install">
            Install
        </a>
                <a class={pathname.slice(1) === 'about' ? 'active p-2 mx-2' : 'p-2 mx-2'} href="/about" >
            About
        </a>
    </div>
</nav>
<script>
const homeLink = document.getElementById("home");
const installLink = document.getElementById("install");
const aboutLink = document.getElementById("about");

</script>
<style>
    .active{
        color: aqua;
    }
</style>
