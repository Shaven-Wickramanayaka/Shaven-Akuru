---

import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Shaven Akuru</title>
	<link rel="shortcut icon" href="/Shaven-Akuru/favicon.svg" type="image/x-icon">
</head>
<body class="bg-light-background">
	<Navbar></Navbar>
	<div class="background">
	</div>
	<slot/>

</body>
</html>

<style>

	@keyframes flicker {
		to {
			mask-position: 50% 50%, 0 50%;
		}
	}

.background{
	position: fixed;
	top: 0;
	left: 0;
	width: 100vw;
	height: 100vh;
	z-index: -1;
	pointer-events: none;
	background: conic-gradient(from 180deg at 50% 70%,#550c18 0deg,#a5907e 72.0000010728836deg,#786452 144.0000021457672deg,#443730 216.00000858306885deg,#550c18 288.0000042915344deg,#f7dad9 1turn);
  	mask:radial-gradient(circle at 50% 50%, white 3px, transparent 2.5px) 50% 50% / 30px 30px,
    url("https://assets.codepen.io/605876/noise-mask.png") 256px 50% / 256px 256px;
  	mask-composite: intersect;
	animation: flicker 20s infinite linear;
}
</style>