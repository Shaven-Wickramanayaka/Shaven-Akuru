---
import Layout from "../layouts/Layout.astro";


---
<Layout>
<div class= "flex flex-col justify-center align-top">
    <div class="p-2 m-2 flex flex-row items-center">
        <div class="flex flex-col items-center h-max m-2">
              <p class="mb-2">Download either the true type font file or the open text font file from this website</p>
              <button class="p-2">Download ttf file</button>
              <button class="p-2">Download otf file</button>
        </div>
        <img width="30%" src="https://placehold.co/400" alt="">
    </div>
    <div class="p-2 m-2 flex flex-row-reverse items-center">
        <p>Double click the file to open the whizard and click install</p>
        <img width="30%" src="https://placehold.co/400" alt="">
    </div>
        <div class="p-2 m-2 flex flex-row">
        <p>Use the font anywhere in your system</p>
        <img src="https://placehold.co/400" alt="">
    </div>
</div>
</Layout>