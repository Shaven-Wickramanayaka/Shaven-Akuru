---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<section class="flex justify-center items-center h-[60vh] md:h-screen flex-col text-center">
		<h1 class="text-[5.5rem] md:text-[8.5rem] font-bold shaven-akuru line-clamp-2 leading-19 md:leading-tight">Shaven Akuru</h1>
		<h3 class="mt-7 text-[1.2rem] md:text-[1.6rem]">A playful handwritten font made for <u> <a href="https://typeface.hackclub.com/">Typeface</a></u></h3>

	</section>
	<div class=" text-center h-[30vh] md:h-screen">
			<p class="shaven-akuru text-[5vw]">The quick brown fox jumps over the lazy dog</p>
			<p class="shaven-akuru text-[4vw]">The quick brown fox jumps over the lazy dog</p>
			<p class="shaven-akuru text-[3vw]">The quick brown fox jumps over the lazy dog</p>
			<p class="shaven-akuru text-[2vw]">The quick brown fox jumps over the lazy dog</p>
			<p class="shaven-akuru text-[1.5vw]">The quick brown fox jumps over the lazy dog</p>
			<p class="shaven-akuru text-[1vw]">The quick brown fox jumps over the lazy dog</p>
	</div>
	
	<section class=" flex flex-col text-center h-screen">
		<h2 class="text-[5rem]">Features</h2>
		<div class="flex flex-row justify-around flex-wrap">
			<div class=" flex justify-between flex-col text-center items-center">
				<img src="https://placehold.co/400" alt="" class="rounded-xl w-[70vw] md:w-[80%]">
				<legend class="p-2 m-2">Crisp and clear characters</legend>
			</div>
			<div class=" flex justify-between flex-col text-center items-center">
				<img src="https://placehold.co/400" alt="" class="rounded-xl w-[70vw] md:w-[80%]">
				<legend class="p-2 m-2">Uneven line height for an authentic feel</legend>
			</div>
			<div class=" flex justify-between flex-col text-center items-center">
				<img src="https://placehold.co/400" alt="" class="rounded-xl w-[70vw] md:w-[80%]">
				<legend class="p-2 m-2 mb-10 md:mb-2">Sans serif based for informal nature</legend>
			</div>
		</div>
		<!-- <a href="/install" class="mt-7 h- text-5xl">Install Font</a> -->
	</section>

</Layout>

<style>
	h1{
		color: white;
		background: url("https://media.istockphoto.com/id/507843358/photo/fire-flames-on-black-background.jpg?s=170667a&w=0&k=20&c=hF0fxWGpUL8d7OsI_YCDdJxXO3e8gx3rtTzeOCEdiZI=");
		-webkit-background-clip: text;
		   -webkit-text-fill-color: transparent;
	}
	h2{
		font-family: 'Shaven Akuru', serif;
	}
	h3,legend{
		font-family: 'Roboto Slab', serif;
	}
	
</style>